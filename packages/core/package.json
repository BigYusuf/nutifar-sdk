{
    "name": "@nutifar/core",
    "description": "Internal shared engine used by Nutifar SDKs. Not intended for direct use.",
    "version": "1.0.1",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "qs": "^6.15.0",
        "zod": "^4.3.6"
    }
}