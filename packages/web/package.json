{
  "name": "@nutifar/web",
  "version": "0.0.4",
  "description": "Official Nutifar Web SDK",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "bin": {
    "nutifar": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "pnpm run build:sdk && pnpm run build:cli",
    "build:sdk": "tsup --config tsup.config.ts",
    "build:cli": "tsup --config tsup.cli.config.ts",
    "dev": "tsup --config tsup.config.ts --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nutifar/core": "^1.0.1",
    "firebase": "^12.13.0",
    "ua-parser-js": "^2.0.10"
  },
  "devDependencies": {
    "@types/node": "^24.12.0"
  },
  "engines": {
    "node": ">=18"
  }
}